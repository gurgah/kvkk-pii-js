{
  "name": "kvkk-pii",
  "version": "0.1.3",
  "description": "KVKK uyumlu Türkçe PII detection kütüphanesi — regex, NER, GLiNER",
  "keywords": [
    "pii",
    "kvkk",
    "gdpr",
    "turkish",
    "nlp",
    "privacy",
    "anonymize"
  ],
  "homepage": "https://github.com/gurgah/kvkk-pii-js",
  "repository": {
    "type": "git",
    "url": "https://github.com/gurgah/kvkk-pii-js.git"
  },
  "license": "MIT",
  "author": "gurgah",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  }
}
